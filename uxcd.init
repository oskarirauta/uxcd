#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1
NAME=uxcd
PROG=/usr/sbin/uxcd

start_service() {
	procd_open_instance "uxcd"
	procd_set_param command "$PROG"
	# threshold=3600s timeout=5s retries=0 (never give up on a critical daemon)
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1   # route uxcd's log to syslog (logread)
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	# (re)start once filesystems carrying container bundles are mounted
	procd_add_raw_trigger "mount.add" 3000 /etc/init.d/uxcd start
}
