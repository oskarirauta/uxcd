{
	"luci-app-uxcd": {
		"description": "Manage uxcd containers",
		"read": {
			"ubus": {
				"uxcd": [ "list", "info", "log", "getconfig", "job_list", "job_status", "job_log", "images" ]
			}
		},
		"write": {
			"ubus": {
				"uxcd": [ "start", "stop", "restart", "create", "remove", "setconfig", "pull", "build", "prune", "check_updates" ]
			}
		}
	}
}
